    return;
  }

  const username = String(elements.adminUserCreateUsername?.value || "").trim();
  const displayName = String(elements.adminUserCreateDisplayName?.value || "").trim();
  const password = String(elements.adminUserCreatePassword?.value || "");
  const isAdmin = Boolean(elements.adminUserCreateIsAdmin?.checked);

  state.adminUsers.createPending = true;
  state.adminUsers.status = "姝ｅ湪鍒涘缓鐢ㄦ埛...";
  state.adminUsers.statusTone = "info";
  renderAdmin();

  try {
    const payload = await createAdminUserApi({
      username,
      displayName,
      password,
      isAdmin
    });
