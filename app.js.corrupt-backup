function getAuthUserAccountMeta(user) {
  if (!user || typeof user !== "object") {
    return "";
  }

  if (user.authProvider === "username" || user.username) {
    return `鍚嶅瓧璐﹀彿锛?{user.username || user.displayName || ""}`;
