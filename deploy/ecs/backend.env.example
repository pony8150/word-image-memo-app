# Public site URL used by the backend to generate image asset links.
PUBLIC_BASE_URL=https://your-domain.com

# Backend listen port inside the container network.
PORT=3000

# Container-local uploads path. Keep this aligned with docker-compose volume mounts.
UPLOADS_DIR=/app/uploads

IMAGE_PURGE_RETENTION_HOURS=24
AUTH_SESSION_TTL_DAYS=30

# Optional SMTP configuration. Leave blank to disable email sending.
SMTP_HOST=
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=图个单词

# Optional OpenAI configuration. Fill these only if you use AI-backed features.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=
OPENAI_REASONING_EFFORT=low
