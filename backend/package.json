{
  "name": "tuge-danci-api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "nest build",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "db:init": "ts-node -r tsconfig-paths/register src/scripts/init-db.ts",
    "download:demo-images": "ts-node -r tsconfig-paths/register src/scripts/download-demo-images.ts",
    "sync:bing-url:junior-high": "ts-node -r tsconfig-paths/register src/scripts/sync-bing-url-images.ts --all --media --prune-defaults",
    "sync:bing-url:senior-high": "ts-node -r tsconfig-paths/register src/scripts/sync-bing-url-images.ts --book=senior-high --all --media --prune-defaults",
    "sync:bing-url:postgraduate-redbook": "ts-node -r tsconfig-paths/register src/scripts/sync-bing-url-images.ts --book=postgraduate-redbook --all --media --prune-defaults",
    "import:wordlists": "ts-node -r tsconfig-paths/register src/scripts/import-wordlists.ts",
    "audit:missing-examples": "ts-node -r tsconfig-paths/register src/scripts/audit-missing-examples.ts",
    "fill:missing-examples": "ts-node -r tsconfig-paths/register src/scripts/fill-missing-examples.ts",
    "seed:demo": "ts-node -r tsconfig-paths/register src/scripts/seed-demo.ts",
    "purge:images": "ts-node -r tsconfig-paths/register src/scripts/purge-images.ts"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.0",
    "@nestjs/core": "^10.4.0",
    "@nestjs/platform-express": "^10.4.0",
    "@nestjs/schedule": "^4.1.0",
    "mysql2": "^3.22.3",
    "nodemailer": "^8.0.6",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.0",
    "@types/node": "^22.0.0",
    "@types/nodemailer": "^8.0.0",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.5.4"
  }
}
